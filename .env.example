# Public app configuration
# Local: http://localhost:3000
# Vercel production without custom domain: https://salud-intercultural.vercel.app
# Production custom domain: https://saludintercultural.com
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Salud Intercultural"

# Public analytics and verification
# Optional until analytics/Search Console are enabled.
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_META_PIXEL_ID=""
GOOGLE_SITE_VERIFICATION=""

# Public contact channels
# Both numbers can receive WhatsApp and calls. Primary: +59164175822.
NEXT_PUBLIC_WHATSAPP_NUMBER="+59164175822"
NEXT_PUBLIC_CALL_PHONE="+59164175822"
NEXT_PUBLIC_CONTACT_EMAIL="medicina.tradicional.ea@gmail.com"
NEXT_PUBLIC_GOOGLE_MAPS_URL=""

# Private database
# Neon/Vercel example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"
DATABASE_URL=""

# Private Payload CMS
# Generate with: openssl rand -base64 32
PAYLOAD_SECRET=""
PAYLOAD_PUBLIC_SERVER_URL="http://localhost:3000"
PAYLOAD_DB_SCHEMA="payload"

# Private admin seed/session configuration
# ADMIN_EMAIL and ADMIN_PASSWORD are used by the seed script to create the first admin.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_RESET_PASSWORD_ON_SEED="false"
ADMIN_SESSION_SECONDS="28800"
ADMIN_LOCK_MINUTES="10"

# Private security and build behavior
RATE_LIMIT_MAX="10"
RATE_LIMIT_WINDOW_SECONDS="60"
CMS_READS_DURING_BUILD="false"
