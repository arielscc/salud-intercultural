# Local development environment.
# Copy this file to .env for Prisma, Payload seed scripts, and Next.js local dev.
# Values here are only for the Docker PostgreSQL service in docker-compose.yml.

# Public app configuration
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Salud Intercultural"

# Public analytics and verification
# Keep analytics disabled in local development.
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_META_PIXEL_ID=""
GOOGLE_SITE_VERIFICATION=""

# Public contact channels
NEXT_PUBLIC_WHATSAPP_NUMBER="+59164175822"
NEXT_PUBLIC_CALL_PHONE="+59164175822"
NEXT_PUBLIC_CONTACT_EMAIL="medicina.tradicional.ea@gmail.com"
NEXT_PUBLIC_GOOGLE_MAPS_URL=""

# Private database
DATABASE_URL="postgresql://salud_intercultural:salud_intercultural@localhost:5432/salud_intercultural_dev?schema=public"

# Private Payload CMS
PAYLOAD_SECRET="local-development-secret-change-me"
PAYLOAD_PUBLIC_SERVER_URL="http://localhost:3000"
PAYLOAD_DB_SCHEMA="payload"

# Private media storage
# Empty token keeps Payload media on local filesystem storage.
BLOB_READ_WRITE_TOKEN=""

# Private admin seed/session configuration
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_RESET_PASSWORD_ON_SEED="false"
ADMIN_SESSION_SECONDS="28800"
ADMIN_LOCK_MINUTES="10"

# Private security and build behavior
RATE_LIMIT_MAX="10"
RATE_LIMIT_WINDOW_SECONDS="60"
CMS_READS_DURING_BUILD="false"
