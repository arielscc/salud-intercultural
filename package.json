{
  "name": "salud-intercultural-landing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && payload generate:types && next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run --exclude \"**/*.integration.test.{ts,tsx}\"",
    "test:unit": "vitest run --exclude \"**/*.integration.test.{ts,tsx}\"",
    "test:watch": "vitest --exclude \"**/*.integration.test.{ts,tsx}\"",
    "test:integration": "pnpm test:db:reset && DOTENV_CONFIG_PATH=.env.test node --import dotenv/config ./node_modules/vitest/vitest.mjs run integration.test --pool=forks --no-file-parallelism",
    "test:db:reset": "DOTENV_CONFIG_PATH=.env.test node --import dotenv/config --import tsx scripts/reset-test-database.ts",
    "typecheck": "prisma generate && payload generate:types && next typegen && tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:reset": "node --import dotenv/config --import tsx scripts/reset-database.ts",
    "db:seed:legacy": "tsx prisma/legacy-seed.ts",
    "seed": "pnpm payload:seed",
    "db:studio": "prisma studio",
    "payload": "payload",
    "payload:seed": "node --import tsx scripts/seed-payload.ts",
    "payload:seed:staging": "DOTENV_CONFIG_PATH=.env.staging pnpm payload:seed",
    "payload:generate-types": "payload generate:types"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@next/env": "16.2.6",
    "@payloadcms/db-postgres": "^3.84.1",
    "@payloadcms/next": "^3.84.1",
    "@payloadcms/richtext-lexical": "^3.84.1",
    "@payloadcms/storage-vercel-blob": "^3.84.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.468.0",
    "next": "^16.2.6",
    "payload": "^3.84.1",
    "pg": "^8.20.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.53.2",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^3.4.19",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "prisma": "^7.8.0",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3",
    "vitest": "^4.1.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
